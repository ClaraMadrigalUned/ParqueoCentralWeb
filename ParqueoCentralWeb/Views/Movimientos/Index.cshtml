@model IEnumerable<ParqueoCentralWeb.Models.MovimientoEstacionamiento>

@{
    ViewBag.Title = "Movimientos";
}

<h2>Movimientos de estacionamiento</h2>

@if (TempData["MensajeExito"] != null)
{
    <div class="alert alert-success">
        @TempData["MensajeExito"]
    </div>
}

@if (TempData["MensajeError"] != null)
{
    <div class="alert alert-danger">
        @TempData["MensajeError"]
    </div>
}

<p>
    @Html.ActionLink(
        "Registrar entrada",
        "Create",
        null,
        new { @class = "btn btn-primary" })
</p>

@using (Html.BeginForm("Index", "Vehiculos", FormMethod.Get))
{
    <div class="row">
        <div class="col-md-5">
            <div class="form-group">
                <label for="criterioMovimiento">
                    Buscar por placa o espacio
                </label>

                <input type="text"
                       id="criterioMovimiento"
                       class="form-control"
                       placeholder="Digite una placa o espacio" />
            </div>
        </div>

        <div class="col-md-4">
            <div class="form-group">
                <label for="estadoMovimiento">
                    Estado
                </label>

                <select id="estadoMovimiento"
                        class="form-control">
                    <option value="">Todos</option>
                    <option value="Activo">Activo</option>
                    <option value="Finalizado">Finalizado</option>
                </select>
            </div>
        </div>

        <div class="col-md-3">
            <div class="form-group">
                <label>&nbsp;</label>

                <div>
                    <button type="button"
                            id="btnBuscarMovimiento"
                            class="btn btn-primary">
                        Buscar
                    </button>

                    <button type="button"
                            id="btnLimpiarMovimiento"
                            class="btn btn-default">
                        Limpiar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="contenedorMovimientos">
        @Html.Partial("_TablaMovimientos", Model)
    </div>
}


@if (!Model.Any())
{
    <div class="alert alert-info">
        No existen movimientos registrados.
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {

            function buscarMovimientos() {
                var texto =
                    $("#criterioMovimiento").val();

                var estado =
                    $("#estadoMovimiento").val();

                $.ajax({
                    url: '@Url.Action("BuscarAjax", "Movimientos")',
                    type: "GET",
                    data: {
                        criterio: texto,
                        estado: estado
                    },
                    success: function (resultado) {
                        $("#contenedorMovimientos")
                            .html(resultado);
                    },
                    error: function () {
                        alert(
                            "No fue posible buscar los movimientos."
                        );
                    }
                });
            }

            $("#btnBuscarMovimiento").click(function () {
                buscarMovimientos();
            });

            $("#criterioMovimiento").keyup(function () {
                buscarMovimientos();
            });

            $("#estadoMovimiento").change(function () {
                buscarMovimientos();
            });

            $("#btnLimpiarMovimiento").click(function () {
                $("#criterioMovimiento").val("");
                $("#estadoMovimiento").val("");
                buscarMovimientos();
            });
        });
    </script>
}